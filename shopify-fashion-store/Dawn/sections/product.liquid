{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

<div class="product-images">
  {% for image in product.images %}
    {% render 'image', class: 'product-image', image: image %}
  {% endfor %}
</div>

<div class="product-info">
  <h1>{{ product.title }}</h1>
  {% render 'product-badge', product: product %}
  <p>{{ product.price | money }}</p>
  <p>{{ product.description }}</p>
</div>

<div class="product-form">
  {% form 'product', product %}
    {% assign current_variant = product.selected_or_first_available_variant %}

    <select name="id" id="variant-id">
      {% for variant in product.variants %}
        <option
          value="{{ variant.id }}"
          {% if variant == current_variant %}
            selected="selected"
          {% endif %}
        >
          {{ variant.title }} - {{ variant.price | money }}
        </option>
      {% endfor %}
    </select>

    <input type="number" id="quantity" name="quantity" min="1" value="1">

    <button type="button" id="ajax-add-to-cart">
      Add to Cart (AJAX)
    </button>
    <div id="cart-message"></div>
    {{ form | payment_button }}
  {% endform %}
</div>


<script>
document.addEventListener('DOMContentLoaded', () => {

  const button = document.getElementById('ajax-add-to-cart');

  button.addEventListener('click', async () => {

    const variantId = document.getElementById('variant-id').value;
    const quantity = document.getElementById('quantity').value;

    try {

      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: Number(quantity)
        })
      });

      const data = await response.json();

      document.getElementById('cart-message').innerHTML =
        `${data.title} added to cart successfully`;

      console.log(data);

    } catch (error) {

      console.error(error);

      document.getElementById('cart-message').innerHTML =
        'Something went wrong';

    }

  });

});
</script>

{% schema %}
{
  "name": "t:general.product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
